# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=kidney_office

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Optional: create first admin user if no users exist (only on first run)
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=your-secure-password
# SEED_ADMIN_EMAIL=admin@kidney-office.srvu.ru

# Screens module: path to APK file for download on Настройка экранов page (relative to backend cwd)
# SCREENS_APK_PATH=apk/kidney-office-tv.apk
# Screens: публичный URL сайта (без слэша в конце) — для абсолютных ссылок на видео в feed для ТВ
# API_BASE_URL=https://kidney-office.srvu.ru

# Calls module: local storage path for audio (relative to backend cwd)
# CALLS_AUDIO_DIR=uploads/calls
# Audio transcription (AITunnel)
# AITUNNEL_API_KEY=your-aitunnel-api-key
# AITUNNEL_API_BASE=https://api.aitunnel.ru/v1
# AITUNNEL_AUDIO_PATH=/audio/transcriptions
# AITUNNEL_AUDIO_MODEL=whisper-1

# Polza.ai — чек-листы по процессам (опционально)
# POLZA_API_KEY=your-polza-api-key
# POLZA_BASE_URL=https://api.polza.ai
# POLZA_MODEL=gpt-4o-mini
