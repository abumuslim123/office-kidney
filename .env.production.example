# Kidney Office — production env (kidney-office.srvu.ru)
# Copy to .env.production and fill values. Do not commit .env.production.

# Домен для Caddy и Let's Encrypt (должен указывать на этот сервер)
DOMAIN=kidney-office.srvu.ru

# Database (used by backend and postgres service)
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=kidney_office
DB_PORT=5432

# JWT — generate strong random secrets (e.g. openssl rand -base64 32)
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET

# Frontend origin for CORS (HTTPS после включения SSL)
FRONTEND_URL=https://kidney-office.srvu.ru

# Web Push (VAPID)
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@kidney-office.srvu.ru

# Daily Postgres backup
DB_BACKUP_CRON=0 0 * * *
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_DIR=/backups
DB_BACKUP_HOST_DIR=../backups/postgres

# Optional: first admin user (only if no users exist)
# SEED_ADMIN_EMAIL=admin@kidney-office.srvu.ru
# SEED_ADMIN_PASSWORD=CHANGE_ME
